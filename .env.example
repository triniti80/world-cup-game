# ----------------------------------------------------------------------------
# world-cup-game: example environment file
# Copy to .env and fill in. In Docker Compose, these are read from .env at
# the project root by `docker compose up`.
# ----------------------------------------------------------------------------

# ----- Postgres ---------------------------------------------------------------
POSTGRES_USER=worldcup
POSTGRES_PASSWORD=changeme-in-real-deploy
POSTGRES_DB=worldcup
# DATABASE_URL is what the Node app reads. Inside docker compose the host is
# `db`; outside it's `localhost`.
DATABASE_URL=postgres://worldcup:changeme-in-real-deploy@db:5432/worldcup

# ----- Master encryption key --------------------------------------------------
# 32 bytes, base64-encoded. Kept for the current bootstrap; later phases may use
# it for private invite/admin secrets.
# Generate with: openssl rand -base64 32
MASTER_KEY=

# ----- Session signing --------------------------------------------------------
# 32+ random bytes, used to sign the admin session cookie.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# ----- Scheduled result sync --------------------------------------------------
# Protects /api/cron/fifa-results. Generate with: openssl rand -base64 32
CRON_SECRET=

# ----- App ---------------------------------------------------------------------
# Bind to localhost only by default — only expose off-host behind a reverse
# proxy (Cloudflare Tunnel, Caddy, etc).
PORT=3000
NODE_ENV=production
