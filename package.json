{
  "name": "world-cup-game",
  "version": "0.0.1",
  "private": true,
  "description": "Private World Cup prediction game for friends.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "tsx --test src/**/*.test.ts",
    "test:integration": "RUN_DB_INTEGRATION=1 tsx --env-file=.env --test src/lib/world-cup/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "results:sync": "tsx --env-file=.env scripts/sync-fifa-results.ts",
    "results:sync:dry-run": "tsx --env-file=.env scripts/sync-fifa-results.ts --dry-run",
    "predictions:backfill-random": "tsx --env-file=.env scripts/backfill-random-stage-picks.ts",
    "predictions:backfill-random:dry-run": "tsx --env-file=.env scripts/backfill-random-stage-picks.ts --dry-run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "db:migrate:prod": "node scripts/migrate.mjs",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.36.4",
    "jose": "^5.9.6",
    "next": "^15.1.6",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "drizzle-kit": "^0.30.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
